<%- include("navbar.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/message.css" rel="stylesheet">

<div class="container py-5">

    <div class="chat-container">

        <div class="row g-0">

            <!-- Left Sidebar -->

           <!-- Left Sidebar -->
<div class="col-lg-4">

    <div class="chat-sidebar">

        <div class="sidebar-header">

            <h3>Messages</h3>

            <button class="new-chat-btn">

                ✏️

            </button>

        </div>

        <div class="search-chat">

            <input
                type="text"
                class="form-control"
                placeholder="🔍 Search conversations...">

        </div>

        <!-- User 1 -->

        <div class="chat-user active">

            <img src="/images/profile_boy.jpg" alt="">

            <div class="chat-info">

                <div class="chat-top">

                    <h6>Arun Kumar</h6>

                    <span>10:42 AM</span>

                </div>

                <div class="chat-bottom">

                    <small>Hi! Is this book still available?</small>

                    <span class="badge-msg">2</span>

                </div>

            </div>

        </div>

        <!-- User 2 -->

        <div class="chat-user">

            <img src="/images/profile_girl.jpg" alt="">

            <div class="chat-info">

                <div class="chat-top">

                    <h6>Priya</h6>

                    <span>Yesterday</span>

                </div>

                <div class="chat-bottom">

                    <small>Is the Arduino still available?</small>

                    <span class="badge-msg">1</span>

                </div>

            </div>

        </div>

        <!-- User 3 -->

        <div class="chat-user">

            <img src="/images/profile_bpy2.jpg" alt="">

            <div class="chat-info">

                <div class="chat-top">

                    <h6>Rahul</h6>

                    <span>Yesterday</span>

                </div>

                <div class="chat-bottom">

                    <small>Can you reduce the price?</small>

                </div>

            </div>

        </div>

        <!-- User 4 -->

        <div class="chat-user">

            <img src="/images/profilepic.jpg" alt="">

            <div class="chat-info">

                <div class="chat-top">

                    <h6>Sneha</h6>

                    <span>2 days ago</span>

                </div>

                <div class="chat-bottom">

                    <small>Thank you 😊</small>

                </div>

            </div>

        </div>

    </div>

</div>

            <!-- Chat Area -->

            <!-- Right Chat Area -->
<div class="col-lg-8">

    <div class="chat-box">

        <!-- Chat Header -->

        <div class="chat-header">

            <div class="header-user">

                <img src="/images/profile_boy.jpg" class="profile-pic">

                <div>

                    <h5>Arun Kumar</h5>

                    <span class="online-status">

                        <span class="dot"></span>

                        Online

                    </span>

                </div>

            </div>

            <div class="header-icons">

                <button title="Call">📞</button>

                <button title="Video">📹</button>

                <button title="More">⋮</button>

            </div>

        </div>

        <!-- Product Card -->

        <div class="product-chat-card">

            <img
                src="/images/book1.jpg"
                class="product-thumb">

            <div class="product-details">

                <h5>Engineering Mathematics Book</h5>

                <p class="price">

                    ₹250

                </p>

                <span class="available">

                    Available

                </span>

            </div>

            <a href="/books" class="view-btn">

                View Item

            </a>

        </div>

        <!-- Messages -->

        <div class="chat-body">

            <div class="message-row left">

                <img src="/images/profile_boy.jpg">

                <div class="message received">

                    Hi! Is this book still available?

                    <span class="time">

                        10:42 AM

                    </span>

                </div>

            </div>

            <div class="message-row right">

                <div class="message sent">

                    Yes, it's available.

                    <span class="time">

                        10:43 AM ✓✓

                    </span>

                </div>

            </div>

            <div class="message-row left">

                <img src="/images/profile_boy.jpg">

                <div class="message received">

                    Great! Can we meet tomorrow?

                    <span class="time">

                        10:44 AM

                    </span>

                </div>

            </div>

            <div class="message-row right">

                <div class="message sent">

                    Sure! Let's meet near the college entrance at 11 AM.

                    <span class="time">

                        10:45 AM ✓✓

                    </span>

                </div>

            </div>

        </div>

        <!-- Input -->

        <div class="chat-input">

            <button class="emoji-btn">

                😊

            </button>

            <button class="attach-btn">

                📎

            </button>

            <input
                type="text"
                placeholder="Type your message...">

            <button class="send-btn">

                ➤

            </button>

        </div>

    </div>

</div>

        </div>

    </div>

</div>

<%- include("footer.ejs") %>