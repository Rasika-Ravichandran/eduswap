<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduSwap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/css/categories.css" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/loginModel.css"/>
</head>
<body>
    <%- include("navbar.ejs") %>
    
<section class="category-section">

    <div class="container">

        <div class="row align-items-center">

            <!-- Left Banner -->
            <div class="col-lg-7">

                <img
                    src="/images/books.png"
                    class="img-fluid category-banner"
                    alt="Books">

            </div>

            <!-- Right Content -->
            <div class="col-lg-5">

                <div class="category-content">

                    <h2>BOOKS</h2>

                    <p>
                        Find semester books, reference books,
                        handwritten notes and novels at affordable
                        prices from fellow students.
                    </p>

                    <a href="/books" class="explore-btn">
    Explore Books →
</a>

                    <div class="mini-items">

                        <div class="mini-card">
                            <div class="mini-image">📖</div>
                            <p>Semester</p>
                        </div>

                        <div class="mini-card">
                            <div class="mini-image">📘</div>
                            <p>Reference</p>
                        </div>

                        <div class="mini-card">
                            <div class="mini-image">📝</div>
                            <p>Notes</p>
                        </div>

                        <div class="mini-card">
                            <div class="mini-image">📚</div>
                            <p>Novels</p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>
<!-- Electronics Section -->

<section class="category-section light-bg">

    <div class="container">

        <div class="row align-items-center">

            <!-- Left Content -->

            <div class="col-lg-5">

                <div class="category-content">

                    <h2>💻 ELECTRONICS</h2>

                    <p>
                        Buy and sell laptops, keyboards, headphones,
                        calculators, pendrives and other electronics
                        used by students.
                    </p>

                    <a href="/electronics" class="explore-btn">
                        Explore Electronics →
                    </a>

                    <div class="mini-items">

                        <div class="mini-card">

                            <div class="mini-image">💻</div>

                            <p>Laptop</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">⌨️</div>

                            <p>Keyboard</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🖱️</div>

                            <p>Mouse</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🎧</div>

                            <p>Headphones</p>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Banner -->

            <div class="col-lg-7">

                    <img
        src="/images/electronics.png"
        class="img-fluid category-banner"
        alt="Electronics">

            </div>

        </div>

    </div>

</section>
<!-- IoT Components Section -->

<section class="category-section">

    <div class="container">

        <div class="row align-items-center">

            <!-- Left Banner -->

            <div class="col-lg-7">

                <img
    src="/images/iot.png"
    class="img-fluid category-banner"
    alt="IoT Components">

            </div>

            <!-- Right Content -->

            <div class="col-lg-5">

                <div class="category-content">

                    <h2>🔌 IoT COMPONENTS</h2>

                    <p>
                        Discover Arduino boards, ESP32, sensors,
                        jumper wires, breadboards and project
                        components for your engineering projects.
                    </p>

                    <a href="/iot" class="explore-btn">
                        Explore IoT →
                    </a>

                    <div class="mini-items">

                        <div class="mini-card">

                            <div class="mini-image">⚙️</div>

                            <p>Arduino</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">📡</div>

                            <p>ESP32</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">📍</div>

                            <p>Sensors</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🔋</div>

                            <p>Modules</p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>
<!-- Uniform Section -->

<section class="category-section light-bg">

    <div class="container">

        <div class="row align-items-center">

            <!-- Left Content -->

            <div class="col-lg-5">

                <div class="category-content">

                    <h2>👕 UNIFORMS</h2>

                    <p>
                        Buy and sell college uniforms, lab coats,
                        ID card holders and other student essentials
                        in good condition.
                    </p>

                    <a href="/uniform" class="explore-btn">
                        Explore Uniforms →
                    </a>

                    <div class="mini-items">

                        <div class="mini-card">

                            <div class="mini-image">👕</div>

                            <p>Uniform</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🥼</div>

                            <p>Lab Coat</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🎒</div>

                            <p>Backpack</p>

                        </div>

                        <div class="mini-card">

                            <div class="mini-image">🪪</div>

                            <p>ID Holder</p>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Banner -->

            <div class="col-lg-7">

                <img
    src="/images/uniform.png"
    class="img-fluid category-banner"
    alt="Uniforms">

            </div>

        </div>

    </div>
    

</section>
    <% if (!loggedIn) { %>
    <%- include("partials/loginModal") %>
    <% } %>
    <%- include("footer.ejs") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>