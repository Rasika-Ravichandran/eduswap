<%- include("navbar.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/profile.css" rel="stylesheet">

<div class="container py-5">

    <!-- Profile Header -->

    <div class="profile-header">

        <div class="row align-items-center">

            <div class="col-lg-2 text-center">

                <img src="/images/profile.png" class="profile-img">

            </div>

            <div class="col-lg-7">

                <h2>Rasika Ravichandran</h2>

                <p class="text-muted mb-2">
                    🎓 Builders Engineering College
                </p>

                <p class="text-muted">
                    📍 Erode, Tamil Nadu
                </p>

                <span class="badge bg-success">
                    ✔ Verified Student
                </span>

            </div>

            <div class="col-lg-3 text-end">

                <a href="#" class="btn btn-primary">
                    Edit Profile
                </a>

            </div>

        </div>

    </div>

    <!-- Dashboard -->

    <div class="row mt-5 g-4">

        <div class="col-md-3">

            <div class="dashboard-card">

                <h2>12</h2>

                <p>Active Listings</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h2>25</h2>

                <p>Items Sold</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h2>18</h2>

                <p>Wishlist</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h2>7</h2>

                <p>Messages</p>

            </div>

        </div>

    </div>

    <!-- My Listings -->

    <div class="section-box mt-5">

        <h3>📦 My Listings</h3>

        <hr>

        <div class="listing-item">

            <div>

                <h5>Engineering Mathematics Book</h5>

                <small>₹250</small>

            </div>

            <div>

                <button class="btn btn-outline-primary btn-sm">
                    Edit
                </button>

                <button class="btn btn-outline-danger btn-sm">
                    Delete
                </button>

            </div>

        </div>

        <div class="listing-item">

            <div>

                <h5>Arduino Uno Kit</h5>

                <small>₹500</small>

            </div>

            <div>

                <button class="btn btn-outline-primary btn-sm">
                    Edit
                </button>

                <button class="btn btn-outline-danger btn-sm">
                    Delete
                </button>

            </div>

        </div>

    </div>

    <!-- Purchase History -->

    <div class="section-box mt-5">

        <h3>🛒 Purchase History</h3>

        <hr>

        <div class="listing-item">

            <div>

                <h5>Scientific Calculator</h5>

                <small>Purchased for ₹650</small>

            </div>

            <span class="badge bg-success">

                Purchased

            </span>

        </div>

    </div>

    <!-- Reviews -->

    <div class="section-box mt-5">

        <h3>⭐ Reviews</h3>

        <hr>

        <div class="review">

            ⭐⭐⭐⭐⭐

            <p>
                Very genuine seller. Product exactly matched the description.
            </p>

        </div>

        <div class="review">

            ⭐⭐⭐⭐⭐

            <p>
                Friendly communication and quick response.
            </p>

        </div>

    </div>

    <!-- Settings -->

    <div class="section-box mt-5 mb-5">

        <h3>⚙️ Account Settings</h3>

        <hr>

        <div class="d-grid gap-3">

            <button class="btn btn-outline-primary">
                Edit Profile
            </button>

            <button class="btn btn-outline-secondary">
                Change Password
            </button>

            <button class="btn btn-outline-danger">
                Logout
            </button>

        </div>

    </div>

</div>

<%- include("footer.ejs") %>