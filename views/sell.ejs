<%- include("navbar.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/sell.css" rel="stylesheet">

<div class="container py-5">

    <!-- Hero Banner -->

    <section class="sell-hero">

        <div class="row align-items-center">

            <div class="col-lg-8">

                <div class="hero-content">

                    <div class="hero-icon">

                        📦

                    </div>

                    <div>

                        <h1>Sell Your Item</h1>

                        <p>
                            List your books, electronics, IoT components,
                            uniforms and connect with students instantly.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-lg-4 text-center">

                <img
                    src="/images/sell1.jpg"
                    class="img-fluid hero-image"
                    alt="Sell">

            </div>

        </div>

    </section>
    <!-- Main Content -->

<div class="row g-4">

    <!-- Left Side -->
    <div class="col-lg-8">

        <div class="form-card">

            <h3 class="mb-4">Item Details</h3>

            <form action="/sell" method="POST" enctype="multipart/form-data">

                <div class="row">

                    <!-- Category -->
                    <div class="col-md-6 mb-4">

                        <label class="form-label">Category</label>

                        <select class="form-select" name="category">

                            <option selected disabled>Select Category</option>

                            <option>Books</option>

                            <option>Electronics</option>

                            <option>IoT Components</option>

                            <option>Uniforms</option>

                        </select>

                    </div>

                    <!-- Item Name -->

                    <div class="col-md-6 mb-4">

                        <label class="form-label">Item Name</label>

                        <input
                            type="text"
                            class="form-control"
                            placeholder="Engineering Mathematics Book"
                            name="title">

                    </div>

                </div>

                <!-- Description -->

                <div class="mb-4">

                    <label class="form-label">Description</label>

                    <textarea
                        class="form-control"
                        rows="5"
                        placeholder="Describe your product..."
                        name="description"></textarea>

                </div>

                <div class="row">

                    <!-- Price -->

                    <div class="col-md-6 mb-4">

                        <label class="form-label">Price (₹)</label>

                        <input
                            type="number"
                            class="form-control"
                            placeholder="500"
                            name="price">

                    </div>

                    <!-- Condition -->

                    <div class="col-md-6 mb-4">

                        <label class="form-label">Condition</label>

                        <select class="form-select" name="condition">

                            <option>New</option>

                            <option>Like New</option>

                            <option>Good</option>

                            <option>Used</option>

                        </select>

                    </div>

                </div>

                <!-- Contact -->

                <div class="mb-4">

                    <label class="form-label">Contact Number</label>

                    <input
                        type="text"
                        class="form-control"
                        placeholder="+91 XXXXX XXXXX"
                        name="phone">

                </div>

                <!-- Upload -->

                <!-- Upload Images -->

<div class="mb-4">

    <label class="form-label">Upload Images</label>

    <div class="upload-box">

        <div class="upload-icon">
            📷
        </div>

        <h5>Drag & Drop Images Here</h5>

        <p>or click below to browse your files</p>

        <input
            class="form-control mt-3"
            type="file"
            name="images"
            multiple>

        <small class="text-muted">
            Maximum 5 images (JPG, PNG)
        </small>

    </div>

</div>

                <div class="d-flex justify-content-between mt-4">

    <a href="/" class="btn btn-outline-secondary px-4">

        Cancel

    </a>

    <button class="btn btn-primary px-5">

        🚀 Post Item

    </button>

</div>

            </form>

        </div>

    </div>

    <!-- Right Side -->

    <div class="col-lg-4">

        <div class="preview-card">

            <h4>Live Preview</h4>

            <hr>

            <img
                src="https://placehold.co/400x260"
                class="preview-image">

            <h5 class="mt-3">

                Item Name

            </h5>

            <p class="text-muted">

                Your description will appear here.

            </p>

            <h3 class="text-primary">

                ₹0

            </h3>

            <span class="badge bg-success">

                Available

            </span>

        </div>
        <div class="tips-card mt-4">

    <h4>💡 Tips for Selling</h4>

    <hr>

    <ul>

        <li>📸 Upload clear photos.</li>

        <li>📝 Write an honest description.</li>

        <li>💰 Set a reasonable price.</li>

        <li>⚡ Reply to buyers quickly.</li>

        <li>🤝 Meet buyers in a safe place.</li>

    </ul>

</div>

    </div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

<%- include("footer.ejs") %>