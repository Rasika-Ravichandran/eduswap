<%- include("navbar.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/heroin.css" rel="stylesheet"/>

<section class="container py-5">

    <div class="page-header">

        <h1>👕 Uniforms</h1>

        <p>Buy and sell college uniforms and student essentials.</p>

    </div>

    <div class="search-box mb-5">

        <input
            type="text"
            class="form-control"
            placeholder="Search Uniforms">

    </div>

    <div class="row g-4">

        <!-- Product 1 -->
        <div class="col-xl-2 col-lg-3 col-md-4 col-6">

            <div class="product-card">

                <span class="status">Available</span>

                <img src="/images/uniform1.jpg"
                     class="product-image">

                <div class="product-title">
                    CSE College Uniform
                </div>

                <div class="product-subtitle">
                    Size M
                </div>

                <p class="product-price">
                    ₹600
                </p>

            </div>

        </div>

        <!-- Product 2 -->
        <div class="col-xl-2 col-lg-3 col-md-4 col-6">

            <div class="product-card">

                <span class="status">Available</span>

                <img src="/images/uniform2.jpg"
                     class="product-image">

                <div class="product-title">
                    Lab Coat
                </div>

                <div class="product-subtitle">
                    Size L
                </div>

                <p class="product-price">
                    ₹350
                </p>

            </div>

        </div>

        <!-- Product 3 -->
        <div class="col-xl-2 col-lg-3 col-md-4 col-6">

            <div class="product-card">

                <span class="status">Available</span>

                <img src="/images/uniform3.jpg"
                     class="product-image">

                <div class="product-title">
                    College Backpack
                </div>

                <div class="product-subtitle">
                    Good Condition
                </div>

                <p class="product-price">
                    ₹500
                </p>

            </div>

        </div>

    </div>

</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

<%- include("footer.ejs") %>